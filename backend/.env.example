# Database Configuration
# REQUIRED: Set your actual database URL
DATABASE_URL="postgresql://user:password@localhost:5432/medibloc"

# Password for database replacement if using variable substitution
PASSWORD="your_database_password"

# JWT Configuration (REQUIRED - SECURITY CRITICAL)
# WARNING: Never use default values in production
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# This secret is used to sign and verify JWT tokens - keep it secure!
JWT_SECRET="your-super-secret-jwt-key-generate-a-strong-one-with-at-least-32-chars"
JWT_EXPIRES_IN="7d"

# Server Configuration
PORT=3000
NODE_ENV="development"

# CORS Configuration
# For development: http://localhost:5173
# For production: https://yourdomain.com
# For multiple origins: https://a.com,https://b.com
# SECURITY WARNING: Never use '*' in production - it allows any domain to access your API
CORS_ORIGIN="http://localhost:5173"
CORS_CREDENTIALS="false"
