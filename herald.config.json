{
  "ignore": [
    "node_modules",
    "dist",
    "build",
    "coverage",
    "logs",
    "backend/test",
    "backend/dist",
    "medibloc/dist",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/*.min.js",
    ".idea",
    ".vscode"
  ],
  "rules": {
    "disable": []
  },
  "thresholds": {
    "maxFileLines": 500,
    "maxCyclomaticComplexity": 15,
    "maxDuplicateLines": 5
  }
}